version: '3.8'

networks:
  app-net:
    driver: bridge

volumes:
  app-datastore:

services:
  app-mysqldb-base:
    container_name: app-mysqldb-base
    restart : unless-stopped
    image: mysql:latest
    networks:
      - app-net
    environment:
      MYSQL_ROOT_PASSWORD: R1s3xSwZ^jjp3^7CTy
      MYSQL_DATABASE:       app
    volumes:
      - app-datastore:/var/lib/mysql:rw

  app-php-base:
    build:
      context: ./
    container_name: app-php
    restart : unless-stopped
    image: app-php:latest
    env_file:
      - ./.env
    networks:
      - app-net
    working_dir: /var/www/html/app
    volumes:
      - ./:/var/www/html/app